# Copy to .env on the server (never commit .env):
#   cp .env.example .env
#
# Required: password for the in-container PostgreSQL user (roveltia).
POSTGRES_PASSWORD=

# Optional: published port on the host (default 8081). Point nginx/Caddy here.
# ROVELTIA_HOST_PORT=8081

# Optional overrides (normally set by docker/docker-entrypoint.sh):
# ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5432;Database=roveltia;Username=roveltia;Password=...
# Database__AutoMigrate=true
