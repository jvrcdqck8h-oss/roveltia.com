{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Roveltia.Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/Roveltia.Web/bin/Debug/net10.0/Roveltia.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Roveltia.Web",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://127.0.0.1:5080"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      }
    }
  ]
}
