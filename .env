# Copy to .env on the server (never commit .env):
#   cp .env.example .env
#
# Optional: published port on the host (default 8081). Point nginx/Caddy here.
# ROVELTIA_HOST_PORT=8081

# Required: SQL Server connection string.
ConnectionStrings__DefaultConnection=Server=sql.example.com,1433;Database=Roveltia;User Id=sql_user;Password=change-me;TrustServerCertificate=true

# Optional: apply EF Core migrations automatically on app startup.
Database__AutoMigrate=true

# Required for sending waitlist emails from the app.
Email__PublicBaseUrl=https://roveltia.com
Email__FromAddress=hello@roveltia.com
Email__FromName=Roveltia
# Optional reply-to address.
Email__ReplyToAddress=hello@roveltia.com
Email__WelcomeSubject=Welcome to the Roveltia waitlist
# Optional override. Use \n for line breaks in env values.
# Email__WelcomeBody=Hi there,\n\nThanks for joining the Roveltia waitlist.\n\nUnsubscribe anytime: {{unsubscribe_url}}
Email__Smtp__Host=smtp.mail.me.com
Email__Smtp__Port=587
Email__Smtp__Username=your-email@example.com
Email__Smtp__Password=change-me
Email__Smtp__EnableSsl=true

# Required to call the protected waitlist campaign API.
Admin__CampaignApiKey=change-me
