<EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" class="@FormClass">
    <DataAnnotationsValidator />
    <div class="waitlist-form__row">
        <label class="waitlist-form__label" for="@InputId">Email address</label>
        <InputText id="@InputId"
                   @bind-Value="_model.Email"
                   class="waitlist-form__input"
                   placeholder="@Placeholder"
                   type="email"
                   autocomplete="email"
                   disabled="@_submitting" />
        <div class="waitlist-form__trap" aria-hidden="true">
            <label class="waitlist-form__label" for="@WebsiteInputId">Leave this field empty</label>
            <InputText id="@WebsiteInputId"
                       @bind-Value="_model.Website"
                       class="waitlist-form__input"
                       type="text"
                       autocomplete="off"
                       tabindex="-1"
                       disabled="@_submitting" />
        </div>
        <button type="submit" class="waitlist-form__submit @(Variant == "hero" ? "waitlist-form__submit--hero" : "")" disabled="@_submitting">
            @SubmitLabel
        </button>
    </div>
    <ValidationMessage For="() => _model.Email" class="waitlist-form__error" />
    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <p class="@StatusClass" role="status">@_statusMessage</p>
    }
    @if (!_submitting && string.IsNullOrEmpty(_statusMessage) && !string.IsNullOrEmpty(Hint))
    {
        <p class="waitlist-form__hint @(Variant == "footer" ? "waitlist-form__hint--footer" : "")">@Hint</p>
    }
</EditForm>

@inject IWaitlistSignupService WaitlistSignup

@code {
    [Parameter] public string FormId { get; set; } = "waitlist";

    /// <summary>Pass "hero" for high-contrast primary button on dark hero backgrounds.</summary>
    [Parameter] public string Variant { get; set; } = "default";

    /// <summary>Optional support line below the field (e.g. launch benefits or no-spam reassurance).</summary>
    [Parameter] public string? Hint { get; set; }

    [Parameter] public string Placeholder { get; set; } = "you@example.com";

    [Parameter] public EventCallback<WaitlistSignupResult> OnSubmitResult { get; set; }

    private string FormClass => Variant switch
    {
        "hero" => "waitlist-form waitlist-form--hero",
        "footer" => "waitlist-form waitlist-form--footer",
        _ => "waitlist-form",
    };

    private readonly EmailModel _model = new();
    private bool _submitting;
    private string? _statusMessage;
    private bool _statusIsError;

    private string InputId => $"{FormId}-email";
    private string SubmitLabel => _submitting ? "Subscribing..." : "Join the waitlist";
    private string StatusClass => _statusIsError ? "waitlist-form__error" : "waitlist-form__thanks";

    private async Task HandleSubmitAsync()
    {
        _statusMessage = null;
        _statusIsError = false;
        _submitting = true;

        try
        {
            var result = await WaitlistSignup.SubscribeAsync(new WaitlistSubscribeRequest(_model.Email!, _model.Website));

            if (OnSubmitResult.HasDelegate)
            {
                await OnSubmitResult.InvokeAsync(result);
            }

            (_statusMessage, _statusIsError) = result switch
            {
                WaitlistSignupResult.Subscribed => ("Thanks! You're on the waitlist.", false),
                WaitlistSignupResult.AlreadySubscribed => ("That email is already subscribed.", false),
                WaitlistSignupResult.SuspectedBot => ("Thanks! You're on the waitlist.", false),
                _ => ("Something went wrong. Please try again in a moment.", true),
            };
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class EmailModel
    {
        [Required(ErrorMessage = "Enter an email address.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string? Email { get; set; }

        public string? Website { get; set; }
    }

    private string WebsiteInputId => $"{FormId}-website";

}
