@page "/"
@rendermode InteractiveServer

<PageTitle>@SeoContent.HomeTitle</PageTitle>

<HeadContent>
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="description" content="@SeoContent.HomeDescription" />
    <link rel="canonical" href="@SeoContent.HomeCanonical" />
    <link rel="alternate" hreflang="en" href="@SeoContent.HomeCanonical" />
    <link rel="alternate" hreflang="x-default" href="@SeoContent.HomeCanonical" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@SeoContent.SiteName" />
    <meta property="og:title" content="@SeoContent.HomeTitle" />
    <meta property="og:description" content="@SeoContent.HomeDescription" />
    <meta property="og:url" content="@SeoContent.HomeCanonical" />
    <meta property="og:image" content="@SeoContent.OgImageUrl" />
    <meta property="og:image:width" content="@SeoContent.OgImageWidth" />
    <meta property="og:image:height" content="@SeoContent.OgImageHeight" />
    <meta property="og:locale" content="@SeoContent.Locale" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@SeoContent.HomeTitle" />
    <meta name="twitter:description" content="@SeoContent.HomeDescription" />
    <meta name="twitter:image" content="@SeoContent.OgImageUrl" />
    <script type="application/ld+json">@((MarkupString)HomeJsonLd)</script>
</HeadContent>

<div class="landing-page">
<a class="skip-link" href="#main-content">Skip to main content</a>

<div class="site-top">
    <aside class="announcement-bar" role="status">
        Roveltia is launching on MakerWorld Crowdfunding soon! Be the first to get early access and exclusive backer rewards.
    </aside>
    <header class="site-header">
        <div class="site-header-inner">
            <a class="site-logo" href="/">Roveltia</a>
            <nav class="site-nav" aria-label="On this page">
                <a href="#overview">Overview</a>
                <a href="#features">Features</a>
                <a href="#backers">Backers</a>
                <a href="#tiers">Tiers</a>
                <a href="#compare">Compare</a>
                <a href="#waitlist">Waitlist</a>
            </nav>
        </div>
    </header>
</div>

<main id="main-content" class="landing-shell" tabindex="-1">
    <section class="hero-section" aria-labelledby="hero-heading">
        <div class="hero-backdrop" aria-hidden="true"></div>
        <div class="hero-copy">
            <p class="hero-digital">
                <span class="hero-badge">Coming soon to MakerWorld Crowdfunding</span>
            </p>
            <h1 id="hero-heading">Roveltia — Your Offline Smart Turntable for Product Photography</h1>
            <p class="hero-subhead">
                A fully 3D-printable, ESP32-C6 powered motorized turntable.
                Completely offline. No cloud. No subscriptions. No compromises.
            </p>

            <div class="hero-cta-row">
                <WaitlistForm FormId="hero" Variant="hero" />
                <a class="cta-demo" href="#demo">
                    <span class="cta-demo__play" aria-hidden="true">▶</span>
                    Watch the demo
                </a>
            </div>
        </div>
    </section>

    <section class="demo-section section-band" id="demo" aria-labelledby="demo-heading">
        <div class="section-heading">
            <p class="eyebrow">See it in motion</p>
            <h2 id="demo-heading">Demo video</h2>
            <p class="section-lead">A short walkthrough of Roveltia in action (target 45 to 60 seconds).</p>
        </div>
        <div class="demo-video-wrap">
            @if (!string.IsNullOrEmpty(DemoVideoYoutubeId))
            {
                <iframe class="demo-video-frame"
                        src="@($"https://www.youtube-nocookie.com/embed/{DemoVideoYoutubeId}")"
                        title="Roveltia demo video"
                        loading="lazy"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen></iframe>
            }
            else
            {
                <div class="demo-video-placeholder" role="img" aria-label="Demo video placeholder">
                    <p>Demo video embed goes here.</p>
                    <p class="demo-video-placeholder__hint">Set <code class="inline-code">DemoVideoYoutubeId</code> in <code class="inline-code">Home.razor</code> to your YouTube video ID.</p>
                </div>
            }
        </div>
    </section>

    <section class="feature-section" id="overview">
        <div class="section-heading">
            <p class="eyebrow">Project overview</p>
            <h2>Built for makers who care about privacy and control</h2>
        </div>
        <div class="overview-prose prose-card">
            <p>
                Roveltia is a privacy-focused, maker-built smart turntable designed for effortless 360° product photography, smooth video spins, and content creation.
                Print the parts on your 3D printer, add affordable electronics, and assemble a professional-grade tool that lives completely offline.
                Control everything from your phone via its own WiFi access point. No internet connection required.
            </p>
        </div>
    </section>

    <section class="feature-section section-band" id="features">
        <div class="section-heading">
            <p class="eyebrow">Capabilities</p>
            <h2>Key features</h2>
        </div>
        <div class="feature-cards">
            <article class="feature-card">
                <span class="feature-card__icon" aria-hidden="true">◎</span>
                <h3 class="feature-card__title">Fully offline</h3>
                <p class="feature-card__text">Creates its own WiFi (SSID: Roveltia), responsive web UI, and mDNS (<code class="inline-code">http://roveltia.local</code>).</p>
            </article>
            <article class="feature-card">
                <span class="feature-card__icon" aria-hidden="true">↻</span>
                <h3 class="feature-card__title">Precise motor control</h3>
                <p class="feature-card__text">Continuous rotation from 0.2 to 3.0 RPM plus accurate step movements.</p>
            </article>
            <article class="feature-card">
                <span class="feature-card__icon" aria-hidden="true">◉</span>
                <h3 class="feature-card__title">Photo workflows</h3>
                <p class="feature-card__text">Multi-frame sequences, shutter triggering, and return-to-home positioning.</p>
            </article>
            <article class="feature-card">
                <span class="feature-card__icon" aria-hidden="true">⌁</span>
                <h3 class="feature-card__title">Flexible control</h3>
                <p class="feature-card__text">Phone or browser UI plus optional IR remote support.</p>
            </article>
            <article class="feature-card">
                <span class="feature-card__icon" aria-hidden="true">⚡</span>
                <h3 class="feature-card__title">ESP32-C6</h3>
                <p class="feature-card__text">Reliable performance and room to grow with firmware updates.</p>
            </article>
            <article class="feature-card">
                <span class="feature-card__icon" aria-hidden="true">▣</span>
                <h3 class="feature-card__title">Bambu Lab ready</h3>
                <p class="feature-card__text">High-quality STLs with tested profiles and AMS multi-color options.</p>
            </article>
        </div>
    </section>

    <section class="feature-section" id="backers">
        <div class="section-heading">
            <p class="eyebrow">Campaign</p>
            <h2>What backers will get</h2>
            <p class="section-lead">When the campaign launches, MakerWorld backers receive the complete digital build kit:</p>
        </div>
        <div class="backers-table-wrap">
            <table class="backers-table">
                <caption class="sr-only">Backer tiers and what is included</caption>
                <thead>
                    <tr>
                        <th scope="col">Tier</th>
                        <th scope="col">What is included</th>
                        <th scope="col">Best for</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th scope="row">Standard</th>
                        <td>STLs, full assembly guide, BOM, firmware, web UI</td>
                        <td>Everyday product shots</td>
                    </tr>
                    <tr>
                        <th scope="row">Creator</th>
                        <td>Everything in Standard plus advanced timing and flash tools</td>
                        <td>Professional photography</td>
                    </tr>
                    <tr>
                        <th scope="row">Developer</th>
                        <td>Full source code plus everything else</td>
                        <td>Tinkerers and custom mods</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <p class="overview-prose overview-prose--tight">
            Everything is designed for a smooth build experience with clear instructions, photos, and troubleshooting tips.
        </p>
    </section>

    <section class="tiers-section section-band" id="tiers">
        <div class="section-heading">
            <p class="eyebrow">Tiers</p>
            <h2>Choose your Roveltia version</h2>
            <p class="section-lead">All versions include the same hardware files and IR remote support. Pick the firmware level that fits your workflow.</p>
        </div>

        <div class="tier-picker" role="group" aria-label="Roveltia versions">
            @foreach (var tier in Tiers)
            {
                <button type="button"
                        class="@(SelectedTier.Id == tier.Id ? "tier-tab active" : "tier-tab")"
                        aria-pressed="@(SelectedTier.Id == tier.Id)"
                        @onclick="() => SelectTier(tier.Id)">
                    <span>@tier.Name</span>
                    @if (!string.IsNullOrEmpty(tier.TabHint))
                    {
                        <small>@tier.TabHint</small>
                    }
                </button>
            }
        </div>

        <div class="tier-spotlight" id="tier-spotlight">
            <div class="tier-headline">
                <p class="tier-eyebrow-name">@SelectedTier.Name</p>
                <h3>@SelectedTier.Tagline</h3>
                <p class="tier-lede">@SelectedTier.Description</p>
            </div>

            <div class="tier-columns tier-columns--single">
                <article>
                    <h4>Includes</h4>
                    <ul>
                        @foreach (var item in SelectedTier.Includes)
                        {
                            <li>@item</li>
                        }
                    </ul>
                    <p class="tier-ideal"><strong>Best for:</strong> @SelectedTier.IdealFor</p>
                </article>
            </div>
        </div>
    </section>

    <section class="feature-section makerworld-section section-band" id="makerworld">
        <div class="section-heading">
            <p class="eyebrow">MakerWorld</p>
            <h2>Why we are crowdfunding on MakerWorld</h2>
        </div>
        <div class="overview-prose">
            <p>
                We want to deliver the highest-quality experience possible: polished documentation, thoroughly tested Bambu Lab print profiles, multiple size variants, and excellent support.
                Crowdfunding lets us invest the time to make Roveltia truly beginner-friendly for the maker community while keeping it fully owned by you (no subscriptions ever).
            </p>
        </div>
    </section>

    <section class="feature-section waitlist-section section-band section-band--accent" id="waitlist">
        <div class="section-heading">
            <p class="eyebrow">Updates</p>
            <h2>Stay in the loop</h2>
            <p class="section-lead">The best way to follow progress and get notified when the campaign goes live is to join the waitlist.</p>
        </div>
        <WaitlistForm FormId="footer" />
    </section>

    <section class="comparison-section" id="compare">
        <div class="section-heading">
            <p class="eyebrow">Compare</p>
            <h2>Decide at a glance</h2>
        </div>

        <p class="table-scroll-hint" aria-hidden="true">Swipe or scroll on small screens</p>
        <div class="comparison-table-wrap" role="region" aria-label="Tier comparison" tabindex="0">
            <table class="comparison-table">
                <caption class="sr-only">Compare features across Standard, Creator, and Developer</caption>
                <thead>
                    <tr>
                        <th scope="col"><span class="sr-only">Feature</span></th>
                        <th scope="col">Standard</th>
                        <th scope="col">Creator</th>
                        <th scope="col">Developer</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var feature in ComparisonRows)
                    {
                        <tr>
                            <th scope="row">@feature.Name</th>
                            <td>@feature.Base</td>
                            <td>@feature.Creator</td>
                            <td>@feature.Developer</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <footer class="site-footer site-footer--cta">
        <p class="footer-cta">Ready to build your own professional product photography turntable?</p>
        <p class="footer-cta-sub">Join the waitlist and be among the first to support Roveltia on MakerWorld.</p>
        <p class="site-footer__legal">© 2026 Roveltia — A project built for makers, by a maker.</p>
    </footer>
</main>
</div>

@code {
    /// <summary>Set to your YouTube video ID (e.g. the part after v=) to show the demo embed; leave null for a placeholder.</summary>
    private static string? DemoVideoYoutubeId = null;

    private static readonly string HomeJsonLd = JsonSerializer.Serialize(
        new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebSite",
            ["name"] = SeoContent.SiteName,
            ["url"] = SeoContent.HomeCanonical,
            ["description"] = SeoContent.HomeDescription,
            ["image"] = SeoContent.OgImageUrl,
            ["publisher"] = new Dictionary<string, object?>
            {
                ["@type"] = "Organization",
                ["name"] = SeoContent.SiteName,
                ["url"] = SeoContent.SiteUrl
            }
        });

    private readonly List<TierModel> Tiers =
    [
        new()
        {
            Id = "roveltia",
            Name = "Roveltia",
            TabHint = "Standard",
            Tagline = "The standard Roveltia experience",
            Description = "Web UI on the Roveltia access point, continuous rotation (0.2 to 3.0 RPM), step moves, multi-frame auto sequence, shutter, return to home, set zero, IR remote (same as every tier), and core settings, without Creator flash workflow tools.",
            IdealFor = "Everyday product photography, 360s, and video with browser or remote control.",
            Includes =
            [
                "STL pack",
                "Roveltia firmware (.bin)",
                "Web UI and live status (WebSocket)",
                "WiFi AP control (join network Roveltia)",
                "Continuous rotation, step moves, auto sequence (full revolution, frame counts)",
                "Shutter trigger, return to home, set zero",
                "IR remote (all tiers; handset optional)",
                "Core settings (RPM, step angle, direction, and more)"
            ]
        },
        new()
        {
            Id = "creator",
            Name = "Roveltia Creator",
            TabHint = "Creator",
            Tagline = "Built for photography workflows",
            Description = "Creator adds flash mode: the onboard light sensor arms the workflow, detects strobes, and steps the plate per flash, with optional preflash filtering, shoot-after-settle, and per-frame shutter delay when timing must be exact.",
            IdealFor = "Studios and creators who sync strobes, filter preflash, and tune detection and delays.",
            Includes =
            [
                "Everything in Roveltia",
                "Flash mode (LDR strobe detect, step per flash)",
                "Preflash ignore with timing window",
                "Tunable detection and timing (threshold, delta, settle, debounce, shutter delay, shoot after settle)",
                "Creator firmware (.bin) and photography-oriented documentation"
            ]
        },
        new()
        {
            Id = "developer",
            Name = "Roveltia Developer",
            TabHint = "Developer",
            Tagline = "Made for customization",
            Description = "Full Arduino and ESP32 source and an editable web UI: fork firmware, change pins or behavior, or ship your own interface. Same Creator capabilities in source form.",
            IdealFor = "Custom builds, branded UIs, hardware mods, and teams that compile their own binaries.",
            Includes =
            [
                "Everything in Roveltia Creator",
                "Full firmware source (Arduino IDE / esp32 board package)",
                "Editable web UI (web_page.h and project sources)"
            ]
        }
    ];

    private readonly List<ComparisonRow> ComparisonRows =
    [
        new("IR remote", "✓", "✓", "✓"),
        new("Web UI, WiFi AP, live status (WebSocket)", "✓", "✓", "✓"),
        new("Flash mode (LDR strobe detect, step per flash)", "–", "✓", "✓"),
        new("Preflash ignore (timing window)", "–", "✓", "✓"),
        new("Tunable flash and shutter timing (settle, debounce, delays)", "–", "✓", "✓"),
        new("Full source code", "–", "–", "✓")
    ];

    private TierModel SelectedTier => Tiers.First(tier => tier.Id == selectedTierId);

    private string selectedTierId = "roveltia";

    private void SelectTier(string id)
    {
        selectedTierId = id;
    }

    private sealed class TierModel
    {
        public required string Id { get; init; }
        public required string Name { get; init; }
        public string? TabHint { get; init; }
        public required string Tagline { get; init; }
        public required string Description { get; init; }
        public required string IdealFor { get; init; }
        public required List<string> Includes { get; init; }
    }

    private sealed record ComparisonRow(string Name, string Base, string Creator, string Developer);
}
