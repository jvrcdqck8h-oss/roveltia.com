@page "/"
@rendermode InteractiveServer
@using Roveltia.Web.Models
@inject IJSRuntime JS

<PageTitle>@SeoContent.HomeTitle</PageTitle>

<HeadContent>
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="description" content="@SeoContent.HomeDescription" />
    <link rel="canonical" href="@SeoContent.HomeCanonical" />
    <link rel="alternate" hreflang="en" href="@SeoContent.HomeCanonical" />
    <link rel="alternate" hreflang="x-default" href="@SeoContent.HomeCanonical" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@SeoContent.SiteName" />
    <meta property="og:title" content="@SeoContent.HomeTitle" />
    <meta property="og:description" content="@SeoContent.HomeDescription" />
    <meta property="og:url" content="@SeoContent.HomeCanonical" />
    <meta property="og:image" content="@SeoContent.OgImageUrl" />
    <meta property="og:image:width" content="@SeoContent.OgImageWidth" />
    <meta property="og:image:height" content="@SeoContent.OgImageHeight" />
    <meta property="og:locale" content="@SeoContent.Locale" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@SeoContent.HomeTitle" />
    <meta name="twitter:description" content="@SeoContent.HomeDescription" />
    <meta name="twitter:image" content="@SeoContent.OgImageUrl" />
    <script type="application/ld+json">@((MarkupString)HomeJsonLd)</script>
</HeadContent>

<div class="lp">

<a class="lp__skip" href="#main">Skip to main content</a>

<header class="lp__header">
    <div class="lp__nav">
        <a class="lp__logo" href="/" aria-label="Roveltia home">Roveltia</a>
        <nav class="lp__nav-links" aria-label="Primary navigation">
            <a href="#how">How it works</a>
            <a href="#features">Features</a>
            <a href="#tiers">Tiers</a>
            <a href="#faq">FAQ</a>
            <a class="lp__nav-cta" href="#waitlist">Join the waitlist</a>
        </nav>
    </div>
</header>

<main id="main" class="lp__main" tabindex="-1">

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="hero" id="product" aria-labelledby="hero-h">
        <div class="hero__grid">
            <div class="hero__copy">
                <p class="hero__trust" role="note">
                    Digital build kit only · No physical unit shipped · No cloud · No subscription
                </p>
                <h1 id="hero-h" class="hero__title">
                    Shoot smooth 360° product photos with a fully offline, 3D-printable smart turntable.
                </h1>
                <p class="hero__lead">
                    Build it yourself, control it from your phone, and run repeatable product-photo
                    workflows without cloud apps, subscriptions, or closed hardware.
                </p>
                <div class="hero__actions">
                    <WaitlistForm FormId="hero"
                                  Variant="hero"
                                  Placeholder="Enter your email"
                                  Hint="Early backer updates, launch notice, and prototype progress." />
                    @if (!string.IsNullOrEmpty(DemoVideoYoutubeId))
                    {
                        <a class="btn-ghost" href="#demo">Watch the demo</a>
                    }
                </div>
            </div>
            <div class="hero__visual" aria-hidden="true">
                <div class="turntable">
                    <div class="turntable__glow"></div>
                    <div class="turntable__ring"></div>
                    <div class="turntable__plate"></div>
                    <div class="turntable__base"></div>
                    <span class="turntable__chip">ESP32-C6</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── How it works ──────────────────────────────────────────────── -->
    <section class="sect sect--open section-reveal" id="how" aria-labelledby="how-h">
        <div class="sect__head">
            <p class="eyebrow">How it works</p>
            <h2 id="how-h" class="sect__title">From files to flawless spins</h2>
            <p class="sect__sub">Print the parts, assemble the electronics, and start shooting from your
                phone. Roveltia is designed to take you from download to first spin with as little
                friction as possible.</p>
        </div>
        <ol class="steps">
            @foreach (var (step, i) in HowItWorksSteps.Select((s, i) => (s, i)))
            {
                <li class="steps__item">
                    <span class="steps__num" aria-hidden="true">0@(i + 1)</span>
                    <div class="steps__icon" aria-hidden="true">@((MarkupString)step.IconSvg)</div>
                    <h3 class="steps__title">@step.Title</h3>
                    <p class="steps__text">@step.Text</p>
                </li>
            }
        </ol>
    </section>

    <!-- ── Demo (only shown when a YouTube ID is configured) ─────────── -->
    @if (!string.IsNullOrEmpty(DemoVideoYoutubeId))
    {
        <section class="sect sect--band section-reveal" id="demo" aria-labelledby="demo-h">
            <div class="sect__head">
                <p class="eyebrow">Demo</p>
                <h2 id="demo-h" class="sect__title">See Roveltia in action</h2>
                <p class="sect__sub">Watch a full capture cycle, from first movement to repeatable 360° output.</p>
            </div>
            <div class="video-wrap">
                <iframe class="video-frame"
                        src="@($"https://www.youtube-nocookie.com/embed/{DemoVideoYoutubeId}")"
                        title="Roveltia - watch the 45-second demo"
                        loading="lazy"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen></iframe>
            </div>
        </section>
    }

    <!-- ── Product showcase strip ───────────────────────────────────── -->
    <div class="showcase section-reveal" aria-hidden="true">
        <div class="showcase__wash"></div>
        <div class="turntable turntable--lg">
            <div class="turntable__glow"></div>
            <div class="turntable__ring"></div>
            <div class="turntable__plate"></div>
            <div class="turntable__base"></div>
            <span class="turntable__chip">ESP32-C6</span>
        </div>
        <p class="showcase__caption">
            3D-printable chassis · Phone-controlled spins · Fully offline · 28BYJ-48 stepper · 0.2-3.0 RPM
        </p>
    </div>

    <!-- ── Features ─────────────────────────────────────────────────── -->
    <section class="sect sect--surface section-reveal" id="features" aria-labelledby="feat-h">
        <div class="sect__head">
            <p class="eyebrow">Why Roveltia</p>
            <h2 id="feat-h" class="sect__title">Engineered for offline workflows</h2>
            <p class="sect__sub">The control of a dedicated product-photo tool without forcing you into
                cloud software, subscriptions, or locked hardware.</p>
        </div>
        <div class="feat-grid">
            @foreach (var f in FeatureBlocks)
            {
                <article class="feat-card">
                    <div class="feat-card__icon" aria-hidden="true">@((MarkupString)f.IconSvg)</div>
                    <h3 class="feat-card__title">@f.Title</h3>
                    <p class="feat-card__text">@f.Text</p>
                    @if (!string.IsNullOrEmpty(f.Stat))
                    {
                        <p class="feat-card__stat">@f.Stat</p>
                    }
                    @if (!string.IsNullOrEmpty(f.Technical))
                    {
                        <p class="feat-card__tech">@f.Technical</p>
                    }
                </article>
            }
        </div>
    </section>

    <!-- ── Who it's for ──────────────────────────────────────────────── -->
    <section class="sect section-reveal" id="audiences" aria-labelledby="who-h">
        <div class="sect__head">
            <p class="eyebrow">Who it's for</p>
            <h2 id="who-h" class="sect__title">Built for people who want control</h2>
            <p class="sect__sub">Whether you're shooting products for a store, building tools for your
                studio, or creating hardware workflows, Roveltia is made for hands-on users who want
                repeatable results.</p>
        </div>
        <div class="audience-grid">
            @foreach (var w in WorkflowCards)
            {
                <article class="audience-card">
                    <div class="audience-card__icon" aria-hidden="true">@((MarkupString)w.IconSvg)</div>
                    <h3 class="audience-card__title">@w.Title</h3>
                    <p class="audience-card__text">@w.Text</p>
                </article>
            }
        </div>
    </section>

    <!-- ── Tiers ─────────────────────────────────────────────────────── -->
    <section class="sect sect--tiers section-reveal" id="tiers" aria-labelledby="tiers-h">
        <div class="sect__head">
            <p class="eyebrow">Choose your tier</p>
            <h2 id="tiers-h" class="sect__title">Standard, Creator, or Developer</h2>
            <p class="sect__sub">All three tiers use the same printed hardware. The difference is how far
                you want to go into photography tooling and customization.</p>
        </div>
        <div class="tier-grid" role="list">
            @foreach (var tier in TierCards)
            {
                <article class="tier-card @(tier.Id == "creator" ? "tier-card--featured" : "") @(tier.Badge is not null ? "tier-card--badged" : "")"
                         role="listitem"
                         aria-label="@(tier.Name) tier">
                    @if (tier.Badge is not null)
                    {
                        <span class="tier-card__badge" role="note">@tier.Badge</span>
                    }
                    <h3 class="tier-card__name">@tier.Name</h3>
                    <p class="tier-card__who">@tier.WhoFor</p>
                    <p class="tier-card__detail">@tier.Detail</p>
                </article>
            }
        </div>
        <p class="tier-note">
            Need the full feature breakdown?
            <a href="#compare">Compare every capability in the matrix below.</a>
        </p>
    </section>

    <!-- ── What you get ──────────────────────────────────────────────── -->
    <section class="sect sect--band section-reveal" id="what-you-get" aria-labelledby="wyg-h">
        <div class="sect__head">
            <p class="eyebrow">Included</p>
            <h2 id="wyg-h" class="sect__title">Everything in your digital kit</h2>
            <p class="sect__sub">Download the files, print the parts, assemble the electronics, and run
                the workflow from Roveltia's on-device software.</p>
        </div>
        <ul class="wyg-grid" role="list">
            @foreach (var item in WygDeliverables)
            {
                <li class="wyg-tile">
                    <div class="wyg-tile__icon" aria-hidden="true">@((MarkupString)item.IconSvg)</div>
                    <div class="wyg-tile__body">
                        <span class="wyg-tile__label">@item.Label</span>
                        <span class="wyg-tile__sub">@item.Sub</span>
                    </div>
                </li>
            }
        </ul>
    </section>

    <!-- ── Before you back ───────────────────────────────────────────── -->
    <section class="sect sect--open section-reveal" id="before-you-back" aria-labelledby="byb-h">
        <div class="sect__head">
            <p class="eyebrow">Before you back</p>
            <h2 id="byb-h" class="sect__title">Know what to expect</h2>
            <p class="sect__sub">Get clear on printer requirements, electronics cost, build time, and
                skill level so you can decide with confidence.</p>
        </div>
        <div class="expect-grid" role="list">
            @foreach (var row in BeforeYouBackRows)
            {
                <div class="expect-card" role="listitem">
                    <div class="expect-card__icon" aria-hidden="true">@((MarkupString)row.IconSvg)</div>
                    <div class="expect-card__body">
                        <span class="expect-card__label">@row.Label</span>
                        <p class="expect-card__value">@row.Value</p>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- ── Compare ───────────────────────────────────────────────────── -->
    <section class="sect section-reveal" id="compare" aria-labelledby="cmp-h">
        <div class="sect__head">
            <p class="eyebrow">Compare features</p>
            <h2 id="cmp-h" class="sect__title">Capability matrix</h2>
            <p class="sect__sub">Compare all four tiers side by side. Each tier includes everything
                in the ones below it.</p>
        </div>

        <!-- Mobile: tier highlight blocks + accordion rows -->
        <div class="cmp-mobile glass-card" role="region" aria-label="Tier highlights">
            <div class="cmp-mobile__blocks">
                <div class="cmp-mobile__block">
                    <h3 class="cmp-mobile__h">Standard includes</h3>
                    <ul class="cmp-mobile__list">
                        <li>IR remote support</li>
                        <li>Web UI, WiFi access point, live status</li>
                    </ul>
                </div>
                <div class="cmp-mobile__block cmp-mobile__block--cyan">
                    <h3 class="cmp-mobile__h">Only in Creator+</h3>
                    <ul class="cmp-mobile__list">
                        <li>Flash mode (strobe detect, step per flash)</li>
                        <li>Preflash ignore window</li>
                        <li>Tunable flash and shutter timing</li>
                    </ul>
                </div>
                <div class="cmp-mobile__block cmp-mobile__block--violet">
                    <h3 class="cmp-mobile__h">Only in Developer+</h3>
                    <ul class="cmp-mobile__list">
                        <li>Full firmware and web UI source code</li>
                    </ul>
                </div>
                <div class="cmp-mobile__block cmp-mobile__block--amber">
                    <h3 class="cmp-mobile__h">Only in Commercial</h3>
                    <ul class="cmp-mobile__list">
                        <li>STEP files - editable chassis geometry</li>
                    </ul>
                </div>
            </div>
            <details class="cmp-mobile__more">
                <summary class="cmp-mobile__more-trigger">Show full capability table</summary>
                <div class="cmp-mobile__rows">
                    @foreach (var row in ComparisonRows)
                    {
                        <details class="cmp-row">
                            <summary class="cmp-row__name">@row.Name</summary>
                            <dl class="cmp-row__cells">
                                <div class="cmp-row__cell">
                                    <dt>Standard</dt>
                                    <dd>@FormatCell(row.Base)</dd>
                                </div>
                                <div class="cmp-row__cell">
                                    <dt>Creator</dt>
                                    <dd>@FormatCell(row.Creator)</dd>
                                </div>
                                <div class="cmp-row__cell">
                                    <dt>Developer</dt>
                                    <dd>@FormatCell(row.Developer)</dd>
                                </div>
                                <div class="cmp-row__cell">
                                    <dt>Commercial</dt>
                                    <dd>@FormatCell(row.Commercial)</dd>
                                </div>
                            </dl>
                        </details>
                    }
                </div>
            </details>
        </div>

        <!-- Desktop: full table -->
        <p class="cmp-hint" aria-hidden="true">Scroll horizontally to see all columns on small screens</p>
        <div class="cmp-table-wrap glass-card" role="region" aria-label="Feature comparison table" tabindex="0">
            <table class="cmp-table">
                <caption class="sr-only">Feature comparison: Standard, Creator, Developer, Commercial</caption>
                <thead>
                    <tr>
                        <th scope="col">Capability</th>
                        <th scope="col">
                            <span class="cmp-th-name">Standard</span>
                            <span class="cmp-th-tag">Best entry</span>
                        </th>
                        <th scope="col">
                            <span class="cmp-th-name">Creator</span>
                            <span class="cmp-th-tag">Most popular</span>
                        </th>
                        <th scope="col">
                            <span class="cmp-th-name">Developer</span>
                            <span class="cmp-th-tag">Full access</span>
                        </th>
                        <th scope="col">
                            <span class="cmp-th-name">Commercial</span>
                            <span class="cmp-th-tag">Hardware rights</span>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in ComparisonRows)
                    {
                        <tr>
                            <th scope="row">@row.Name</th>
                            <td class="cmp-table__cell @CellClass(row.Base)">@FormatCell(row.Base)</td>
                            <td class="cmp-table__cell @CellClass(row.Creator)">@FormatCell(row.Creator)</td>
                            <td class="cmp-table__cell @CellClass(row.Developer)">@FormatCell(row.Developer)</td>
                            <td class="cmp-table__cell @CellClass(row.Commercial)">@FormatCell(row.Commercial)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <!-- ── FAQ ───────────────────────────────────────────────────────── -->
    <section class="sect sect--narrow section-reveal" id="faq" aria-labelledby="faq-h">
        <div class="sect__head">
            <p class="eyebrow">FAQ</p>
            <h2 id="faq-h" class="sect__title">Questions, answered</h2>
        </div>
        <FaqAccordion Items="FaqItems" />
    </section>

    <!-- ── Final CTA ─────────────────────────────────────────────────── -->
    <section class="sect sect--cta section-reveal" id="waitlist" aria-labelledby="cta-h">
        <div class="cta-card">
            <p class="eyebrow eyebrow--on-glow">Waitlist</p>
            <h2 id="cta-h" class="cta-card__title">Be first to know when Roveltia launches.</h2>
            <p class="cta-card__sub">Early-backer rewards, campaign day access, and prototype progress
                - straight to your inbox when it matters.</p>
            <WaitlistForm FormId="footer"
                          Variant="footer"
                          Placeholder="Enter your email"
                          Hint="" />
            <ul class="cta-trust" aria-label="Email commitment">
                <li class="cta-trust__item">
                    <svg class="cta-trust__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 4L6.5 10.5 3 7"/></svg>
                    No spam
                </li>
                <li class="cta-trust__item">
                    <svg class="cta-trust__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 4L6.5 10.5 3 7"/></svg>
                    Campaign updates only
                </li>
                <li class="cta-trust__item">
                    <svg class="cta-trust__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 4L6.5 10.5 3 7"/></svg>
                    One-click unsubscribe in every email
                </li>
            </ul>
        </div>
    </section>

    <!-- ── Footer ────────────────────────────────────────────────────── -->
    <footer class="lp__footer">
        <p class="lp__footer-logo">Roveltia</p>
        <p class="lp__footer-tag">
            An offline-first smart turntable kit for makers and product photographers.
        </p>
        <p class="lp__footer-fine">
            © @DateTime.UtcNow.Year Roveltia · Digital build kit only · No cloud · No subscription
        </p>
    </footer>

</main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("roveltiaLandingReveal.init"); }
            catch (JSException) { /* script may not be available in all environments */ }
        }
    }

    private static string? DemoVideoYoutubeId = null;

    private static readonly string HomeJsonLd = JsonSerializer.Serialize(
        new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebSite",
            ["name"] = SeoContent.SiteName,
            ["url"] = SeoContent.HomeCanonical,
            ["description"] = SeoContent.HomeDescription,
            ["image"] = SeoContent.OgImageUrl,
            ["publisher"] = new Dictionary<string, object?>
            {
                ["@type"] = "Organization",
                ["name"] = SeoContent.SiteName,
                ["url"] = SeoContent.SiteUrl
            }
        });

    /* ── FAQ ──────────────────────────────────────────────────────────── */

    private static readonly IReadOnlyList<FaqItem> FaqItems =
    [
        new("finished", "Is Roveltia a finished turntable?",
            "No. Roveltia is a digital build kit, not a pre-assembled product. You download the files " +
            "and firmware, print the parts yourself, and source the electronics from the published BOM."),
        new("cloud", "Does it require cloud services or a subscription?",
            "No. Roveltia runs locally on the device over its own WiFi access point with an on-device " +
            "web UI. No cloud service or subscription is required."),
        new("control", "How do I control it during a shoot?",
            "You connect directly to Roveltia from your phone or browser and control spins, steps, " +
            "sequences, and workflow actions from the built-in interface. An IR remote is also " +
            "supported for hands-free operation."),
        new("tiers", "What is the difference between Standard, Creator, and Developer?",
            "Standard gives you the core build and workflow features. Creator adds advanced " +
            "photography-oriented tools including flash mode, strobe detection, and tunable timing. " +
            "Developer adds source code access for full customization."),
        new("print", "What kind of printer do I need?",
            "Roveltia is designed for FDM printing. The build guide will help you understand the " +
            "expected setup and part requirements before you start."),
    ];

    /* ── How it works ─────────────────────────────────────────────────── */

    private sealed record HowItWorksStep(string Title, string Text, string IconSvg);

    private static readonly IReadOnlyList<HowItWorksStep> HowItWorksSteps =
    [
        new(
            "Print the parts",
            "Use the included STL pack and print guidance to produce the turntable components on your FDM printer.",
            """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>"""),
        new(
            "Assemble with affordable electronics",
            "Follow the BOM and build guide to wire the board, motor driver, LDR sensor, and core hardware with confidence.",
            """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"/></svg>"""),
        new(
            "Control spins from your phone",
            "Connect directly to Roveltia's built-in WiFi and run smooth spins, indexed steps, and photo sequences from the on-device web UI.",
            """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>"""),
    ];

    /* ── Features ─────────────────────────────────────────────────────── */

    private sealed record FeatureBlock(string Title, string Text, string? Stat, string? Technical, string IconSvg);

    private static readonly IReadOnlyList<FeatureBlock> FeatureBlocks =
    [
        new(
            "Works fully offline",
            "Roveltia runs locally over its own WiFi access point. No cloud, no accounts, no app dependency - your workflow is never at the mercy of a server.",
            "No cloud. No subscription.",
            null,
            """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>"""),
        new(
            "Smooth, repeatable motion",
            "Indexed steps and consistent rotation mean every session is identical. Set your frame count once and get the same result every time.",
            "0.2 - 3.0 RPM · 28BYJ-48 stepper",
            null,
            """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>"""),
        new(
            "Built for photo workflows",
            "24, 36, 48, or 72-frame sequences with automatic shutter triggering and return-to-zero. Every run starts from the same position.",
            "24 / 36 / 48 / 72 frame presets",
            null,
            """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>"""),
        new(
            "Control from any phone or browser",
            "Roveltia hosts its own WiFi access point and on-device web UI - nothing to install. An IR remote is also supported for hands-free operation.",
            "No app. Open a browser and shoot.",
            null,
            """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>"""),
    ];

    /* ── Audiences ────────────────────────────────────────────────────── */

    private sealed record WorkflowCard(string Title, string Text, string IconSvg);

    private static readonly IReadOnlyList<WorkflowCard> WorkflowCards =
    [
        new(
